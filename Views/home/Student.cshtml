@{
}
@{
@model STUDENTINFORMATIONN.Controllers.Student
    ViewData["Title"] = "Student Info";
}

<h2>Student Information Form</h2>

<form asp-action="StudentInfo" method="post">
    
    <div>
        <label>Name:</label><br />
        <input asp-for="Name" />
    </div>

    <div>
        <label>Age:</label><br />
        <input asp-for="Age" type="number" />
    </div>

    <div>
        <label>Course:</label><br />
        <input asp-for="Course" />
    </div>

    <br />
    <button type="submit">Submit</button>
</form>

@if (Model != null)
{
    <h3>Entered Information:</h3>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Age:</strong> @Model.Age</p>
    <p><strong>Course:</strong> @Model.Course</p>
}
